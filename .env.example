# Copy to .env and fill in values: cp .env.example .env

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC
# Public URL for email links (use your LAN IP + port when testing from other devices)
SITE_URL=http://127.0.0.1:8000

# Database — sqlite3 (default) | postgresql | mysql
DB_ENGINE=sqlite3
DB_NAME=db.sqlite3
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-user
EMAIL_HOST_PASSWORD=your-password
DEFAULT_FROM_EMAIL=ArcBook <noreply@yourdomain.com>
